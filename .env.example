# Internal-only AudiobookShelf address. This is baked into the nginx proxy
# config at container start. ABS should be reachable ONLY on the internal
# Docker network - do not publish its host port. End users never see this.
ABS_SERVER_URL=http://abs:13378

# The public origin users actually hit (web browser + native ABSORB app).
# Used to rewrite any ABS redirect that would otherwise leak the internal host.
# Must match the scheme/host your TLS terminator serves.
PUBLIC_URL=https://books.mydomain.com

# Port HearthShelf serves on
PORT=9277

# --- QuestGiver AI recommender (optional) ---
# The QuestGiver backend forwards prompts to an AI provider. The key is held
# server-side and never reaches the browser. Leave QG_PROVIDER unset to disable
# the AI path entirely; QuestGiver then uses its built-in heuristic recommender.
#   QG_PROVIDER  : openai | anthropic | gemini
#   QG_MODEL     : provider model id (e.g. gpt-4o-mini, claude-sonnet-4-6, gemini-1.5-flash)
#   QG_API_KEY   : the provider API key (server-side only)
#   QG_BASE_URL  : override the provider base URL (for OpenAI-compatible/self-hosted)
#   QG_LIMIT     : per-user cap - "off" | "N/day" | "N/week" | "N/month"
QG_PROVIDER=
QG_MODEL=
QG_API_KEY=
QG_BASE_URL=
QG_LIMIT=off
# Turn QuestGiver off entirely (hides the page + nav). Default on.
QG_ENABLED=true
# Turn Discover off (history-driven ambient shelves). Default on.
DISCOVER_ENABLED=true
# Where the Discover backend stores per-user feedback + the monthly AI shelf
# cache. Mount this as a volume so it survives restarts. The monthly AI shelf
# reuses the QuestGiver provider (QG_PROVIDER/QG_MODEL/QG_API_KEY); with no
# provider it falls back to a heuristic shelf.
QG_DATA_DIR=/app/data

# --- Cross-user social stats (leaderboard, "finished by") ---
# HearthShelf reads ABS's own SQLite database READ-ONLY to build the server
# leaderboard and per-book "finished by N people" counts - data ABS won't expose
# to non-admins through its API. We never write to this file.
#   HS_ABS_DB_PATH : path to ABS's absdatabase.sqlite as seen from this container.
# On the all-in-one image ABS's /config is already in-container, so the default
# just works. On the slim image, mount ABS's config dir read-only (see
# docker-compose.yml) and point this at the file. Leave the file unmapped and the
# leaderboard simply hides.
HS_ABS_DB_PATH=/config/absdatabase.sqlite

# Default leaderboard sharing for users who haven't chosen for themselves.
# "on" (default) = opt-out: listeners appear unless they hide themselves.
# "off" = opt-in: listeners are hidden unless they turn sharing on. This only
# seeds the initial value; admins change it later under Config > Community, and
# it never overrides a user who set their own preference.
COMMUNITY_DEFAULT_SHARE=on

# --- ReadMeABook acquisition (optional) ---
# Connects HearthShelf to a ReadMeABook server so users can request audiobooks
# (and matching ebooks) that aren't on the shelf yet. HearthShelf talks to RMAB
# as one shared service account, server-side. Leave RMAB_URL unset to hide all
# request UI.
#   RMAB_URL         : RMAB address (e.g. https://audiobooks.example.com)
#   RMAB_LOGIN_TOKEN : a long-lived RMAB login token for the service account.
#                      In RMAB: Admin > Users > (your service user) > enable the
#                      "Login Token" toggle and copy the rmab_... value once.
#                      Give that account the admin role so ebook companion fetch
#                      and admin metrics work. HearthShelf exchanges this token
#                      for a short-lived session automatically.
RMAB_URL=
RMAB_LOGIN_TOKEN=

# --- Audible catalog region (optional) ---
# Marketplace used for HearthShelf's own Audible search (Discover, missing-series
# books). One of: us ca uk au in de es fr. Default us.
AUDIBLE_REGION=us

# --- Audplexus library-sync diagnostics (optional, admin) ---
# Surfaces library-sync issues (owned books that don't match what's in ABS) to
# admins, and enables the "Buy on Audible" affordance. Leave unset to hide it.
#   AUDPLEXUS_URL : Audplexus address (e.g. https://audplexus.example.com)
#   AUDPLEXUS_KEY : an Audplexus API key (Settings > API key in Audplexus)
AUDPLEXUS_URL=
AUDPLEXUS_KEY=
