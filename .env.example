# Internal-only AudiobookShelf address. This is baked into the nginx proxy
# config at container start. ABS should be reachable ONLY on the internal
# Docker network - do not publish its host port. End users never see this.
ABS_SERVER_URL=http://abs:13378

# The public origin users actually hit (web browser + native ABSORB app).
# Used to rewrite any ABS redirect that would otherwise leak the internal host.
# Must match the scheme/host your TLS terminator serves.
PUBLIC_URL=https://books.mydomain.com

# Port HearthShelf serves on
PORT=3000

# --- QuestGiver AI recommender (optional) ---
# The QuestGiver backend forwards prompts to an AI provider. The key is held
# server-side and never reaches the browser. Leave QG_PROVIDER unset to disable
# the AI path entirely; QuestGiver then uses its built-in heuristic recommender.
#   QG_PROVIDER  : openai | anthropic | gemini
#   QG_MODEL     : provider model id (e.g. gpt-4o-mini, claude-sonnet-4-6, gemini-1.5-flash)
#   QG_API_KEY   : the provider API key (server-side only)
#   QG_BASE_URL  : override the provider base URL (for OpenAI-compatible/self-hosted)
#   QG_LIMIT     : per-user cap - "off" | "N/day" | "N/week" | "N/month"
QG_PROVIDER=
QG_MODEL=
QG_API_KEY=
QG_BASE_URL=
QG_LIMIT=off
